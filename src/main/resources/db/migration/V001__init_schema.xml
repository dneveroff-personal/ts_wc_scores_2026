<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-users" author="tswcscores">
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="telegram_id" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="username" type="VARCHAR(64)"/>
            <column name="first_name" type="VARCHAR(64)"/>
            <column name="last_name" type="VARCHAR(64)"/>
            <column name="registered_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="total_points" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-teams" author="tswcscores">
        <createTable tableName="teams">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="external_id" type="INT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="short_name" type="VARCHAR(20)"/>
            <column name="tla" type="VARCHAR(5)"/>
            <column name="crest_url" type="VARCHAR(255)"/>
            <column name="group_name" type="VARCHAR(10)"/>
        </createTable>
    </changeSet>

    <changeSet id="003-matches" author="tswcscores">
        <createTable tableName="matches">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="external_id" type="INT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="home_team_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_match_home" references="teams(id)"/>
            </column>
            <column name="away_team_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_match_away" references="teams(id)"/>
            </column>
            <column name="utc_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)" defaultValue="SCHEDULED">
                <constraints nullable="false"/>
            </column>
            <column name="stage" type="VARCHAR(50)"/>
            <column name="group_name" type="VARCHAR(10)"/>
            <column name="home_score" type="INT"/>
            <column name="away_score" type="INT"/>
            <column name="scores_calculated" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="matches" indexName="idx_match_utc_date">
            <column name="utc_date"/>
        </createIndex>
        <createIndex tableName="matches" indexName="idx_match_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

    <changeSet id="004-predictions" author="tswcscores">
        <createTable tableName="predictions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_pred_user" references="users(id)"/>
            </column>
            <column name="match_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_pred_match" references="matches(id)"/>
            </column>
            <column name="home_score" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="away_score" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="points_earned" type="INT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="predictions"
                             columnNames="user_id,match_id"
                             constraintName="uq_prediction_user_match"/>
    </changeSet>

</databaseChangeLog>
